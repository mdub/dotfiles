#! /Users/mikewilliams/.asdf/installs/ruby/3.4.7/bin/ruby
# frozen_string_literal: true

Gem.paths = { "GEM_HOME" => Gem.user_dir }

require "bundler/inline"

gemfile do
  source "https://rubygems.org"
  gem "clamp"
  gem "oj"
  gem "rainbow"
end

require "json"
require "shellwords"
require "time"

# rubocop:disable Lint/MissingCopEnableDirective
# rubocop:disable Metrics/AbcSize

Session = Struct.new(:session_id, :transcript_path, :project_dir, :started_at, :updated_at, :title, :matching_message,
                     keyword_init: true)

# Searches Claude Code session JSONL files.
class SessionFinder
  DEFAULT_PROJECTS_DIR = File.expand_path("~/.claude/projects")

  def initialize(projects_dir: DEFAULT_PROJECTS_DIR)
    @projects_dir = projects_dir
  end

  def find(cutoff_time:, matching: nil, limit: nil)
    pattern = Regexp.new(Regexp.escape(matching), Regexp::IGNORECASE) if matching
    sessions = find_sessions(cutoff_time, pattern)
    sessions = sessions.last(limit) if limit
    sessions
  end

  private

  def find_sessions(cutoff_time, pattern)
    sessions = []

    Dir.glob("#{@projects_dir}/*/*.jsonl").each do |file|
      updated_at = File.mtime(file)
      next if updated_at < cutoff_time

      session = parse_session(file, pattern)
      next unless session

      session.session_id = File.basename(file, ".jsonl")
      session.transcript_path = file
      session.updated_at = updated_at
      sessions << session
    end

    sessions.sort_by(&:started_at)
  end

  def parse_session(file, pattern)
    return nil if pattern && !File.read(file).match?(pattern)

    state = { title: nil, message: nil, started_at: nil, cwd: nil }
    File.foreach(file) do |line|
      parse_session_line(Oj.load(line), pattern, state)
    rescue StandardError
      next
    end

    return nil unless state[:message]

    Session.new(
      started_at: state[:started_at],
      project_dir: state[:cwd],
      title: state[:title],
      matching_message: state[:message]
    )
  end

  def parse_session_line(entry, pattern, state)
    if entry["type"] == "custom-title"
      state[:title] = entry["customTitle"]
      return
    end

    return if state[:message]

    user_content = extract_user_content(entry)
    return unless user_content

    record_user_message(entry, user_content, pattern, state)
  end

  def record_user_message(entry, content, pattern, state)
    state[:started_at] ||= Time.parse(entry["timestamp"]).localtime
    state[:cwd] ||= entry["cwd"]
    state[:message] = content unless pattern && !pattern.match?(content)
  end

  def extract_user_content(entry)
    return unless entry["type"] == "user"
    return unless entry["permissionMode"]

    content = entry.dig("message", "content")
    return unless content.is_a?(String)
    return if content.start_with?("<") # filter out system-injected messages

    content
  end
end

Clamp do # rubocop:disable Metrics/BlockLength

  self.description = "Manage Claude Code sessions across all projects"

  option %w[--days -d], "DAYS", "maximum age of sessions (default: 7)", default: 7 do |val|
    Integer(val)
  end

  option %w[--matching -m], "STRING", "filter to sessions with a matching user message"

  option %w[--limit -n], "N", "maximum number of sessions to show" do |val|
    Integer(val)
  end

  def sessions
    @sessions ||= begin
      cutoff_time = Time.now - (days * 86_400)
      SessionFinder.new.find(cutoff_time: cutoff_time, matching: matching, limit: limit)
    end
  end

  def simplify_path(path)
    home = ENV.fetch("HOME", nil)
    return path unless home

    path.sub(home, "~")
  end

  option %w[--json -J], :flag, "output as JSON"

  def session_display_name(session)
    session.title || session.matching_message.lines.first&.strip&.slice(0, 80) || session.session_id
  end

  def session_to_hash(session)
    {
      session_id: session.session_id,
      transcript_path: session.transcript_path,
      project_dir: session.project_dir,
      started_at: session.started_at.utc.iso8601,
      updated_at: session.updated_at.utc.iso8601,
      title: session.title,
      matching_message: session.matching_message
    }
  end

  def format_timestamp(time)
    date = Rainbow(time.strftime("%Y-%m-%d")).green
    t = Rainbow("T").faint
    hms = Rainbow(time.strftime("%H:%M:%S")).green
    "#{date}#{t}#{hms}"
  end

  def format_message(text, pattern)
    text.lines.map do |l|
      styled = if pattern
                 l.rstrip.split(/(#{pattern.source})/i).map do |part|
                   pattern.match?(part) ? Rainbow(part).underline : Rainbow(part).faint
                 end.join
               else
                 Rainbow(l.rstrip).faint.to_s
               end
      "  #{Rainbow('|').faint} #{styled}"
    end.join("\n")
  end

  def format_session(session, pattern: nil)
    lines = []
    sid = Rainbow(session.session_id).yellow
    lines << "#{sid} from #{format_timestamp(session.started_at)} to #{format_timestamp(session.updated_at)}"
    lines << "  #{Rainbow(session.title).bright.white}" if session.title
    lines << "  #{Rainbow(simplify_path(session.project_dir)).cyan}"
    lines << format_message(session.matching_message, pattern)
    lines.join("\n")
  end

  subcommand "list", "List recent sessions" do

    option "--[no-]color", :flag, "enable/disable color output"

    def default_color?
      $stdout.tty?
    end

    def execute
      return warn_no_sessions if sessions.empty?

      if json?
        puts JSON.pretty_generate(sessions.map { |session| session_to_hash(session) })
      else
        Rainbow.enabled = color?
        pattern = matching_pattern
        sessions.each do |session|
          puts format_session(session, pattern: pattern)
          puts
        end
      end
    end

  end

  def pick_session
    return warn_no_sessions if sessions.empty?

    Rainbow.enabled = true
    pattern = matching_pattern
    items = sessions.reverse.map { |session| "#{format_session(session, pattern: pattern)}\n" }

    selected_text = fzf_select(items)
    return nil unless selected_text

    selected_id = selected_text.lines.first&.split&.first
    sessions.find { |session| session.session_id == selected_id }
  end

  def warn_no_sessions
    warn "No sessions found"
    nil
  end

  def matching_pattern
    Regexp.new(Regexp.escape(matching), Regexp::IGNORECASE) if matching
  end

  def fzf_select(items)
    IO.popen(["fzf", "--read0", "--print0", "--ansi", "--no-sort"], "r+") do |io|
      io.write(items.join("\0"))
      io.close_write
      result = io.read.chomp("\0")
      return nil if result.empty?

      result
    end
  rescue Errno::ENOENT
    warn "fzf is required"
    nil
  end

  subcommand "select", "Interactively select a session" do

    def execute
      selected = pick_session
      return unless selected

      if json?
        puts JSON.pretty_generate(session_to_hash(selected))
      else
        puts "#{selected.session_id} in #{selected.project_dir}"
      end
    end

  end

  subcommand "resume", "Select and resume a session" do

    option %w[--commands], :flag, "print commands instead of executing"
    option %w[--dangerously-skip-permissions --yolo -Y], :flag, "skip permission checks when resuming"

    def execute
      selected = pick_session
      return unless selected

      cmd = ["claude", "--resume", selected.session_id]
      cmd << "--dangerously-skip-permissions" if dangerously_skip_permissions?

      if commands?
        puts "cd #{selected.project_dir}" if selected.project_dir
        puts Shellwords.join(cmd)
      else
        Dir.chdir(selected.project_dir) if selected.project_dir && File.directory?(selected.project_dir)
        Bundler.with_unbundled_env do
          exec(*cmd)
        end
      end
    end

  end

end
