#! /Users/mikewilliams/.asdf/installs/ruby/3.4.7/bin/ruby
# frozen_string_literal: true

Gem.paths = { "GEM_HOME" => Gem.user_dir }

require "bundler/inline"

gemfile do
  source "https://rubygems.org"
  gem "clamp"
  gem "oj"
  gem "rainbow"
end

require "json"
require "time"

# rubocop:disable Lint/MissingCopEnableDirective
# rubocop:disable Metrics/AbcSize
# rubocop:disable Metrics/MethodLength

Session = Struct.new(:session_id, :project_dir, :started_at, :updated_at, :title, :matching_message, keyword_init: true)

class SessionFinder
  DEFAULT_PROJECTS_DIR = File.expand_path("~/.claude/projects")

  def initialize(projects_dir: DEFAULT_PROJECTS_DIR)
    @projects_dir = projects_dir
  end

  def find(cutoff_time:, matching: nil, limit: nil)
    pattern = Regexp.new(Regexp.escape(matching), Regexp::IGNORECASE) if matching
    sessions = []

    Dir.glob("#{@projects_dir}/*/*.jsonl").each do |file|
      updated_at = File.mtime(file)
      next if updated_at < cutoff_time

      session_id = File.basename(file, ".jsonl")

      result = parse_session(file, pattern)
      next unless result

      started_at, cwd, custom_title, matching_message = result

      sessions << Session.new(
        session_id: session_id,
        project_dir: cwd,
        started_at: started_at,
        updated_at: updated_at,
        title: custom_title,
        matching_message: matching_message
      )
    end

    results = sessions.sort_by(&:started_at)
    results = results.last(limit) if limit
    results
  end

  private

  def parse_session(file, pattern)
    return nil if pattern && !File.read(file).match?(pattern)

    started_at = nil
    cwd = nil
    custom_title = nil
    matching_message = nil

    File.foreach(file) do |line|
      entry = Oj.load(line)

      if entry["type"] == "custom-title"
        custom_title = entry["customTitle"]
        next
      end

      next if matching_message
      next unless entry["type"] == "user"
      next unless entry["message"]

      content = entry["message"]["content"]
      next unless content.is_a?(String)
      next if content.start_with?("This session is being continued from a previous conversation")

      started_at ||= Time.parse(entry["timestamp"]).localtime
      cwd ||= entry["cwd"]

      next if pattern && !pattern.match?(content)

      matching_message = content
    rescue StandardError
      next
    end

    return nil unless matching_message

    [started_at, cwd, custom_title, matching_message]
  end
end

Clamp do

  self.description = "Manage Claude Code sessions across all projects"

  option %w[--days -d], "DAYS", "maximum age of sessions (default: 7)", default: 7 do |s|
    Integer(s)
  end

  option %w[--matching -m], "STRING", "filter to sessions with a matching user message"

  option %w[--limit -n], "N", "maximum number of sessions to show" do |s|
    Integer(s)
  end

  def sessions
    @sessions ||= begin
      cutoff_time = Time.now - (days * 86_400)
      SessionFinder.new.find(cutoff_time: cutoff_time, matching: matching, limit: limit)
    end
  end

  def simplify_path(path)
    home = ENV["HOME"]
    return path unless home

    path.sub(home, "~")
  end

  option %w[--json -J], :flag, "output as JSON"

  def session_display_name(s)
    s.title || s.matching_message.lines.first&.strip&.slice(0, 80) || s.session_id
  end

  def session_to_hash(s)
    {
      session_id: s.session_id,
      project_dir: s.project_dir,
      started_at: s.started_at.utc.iso8601,
      updated_at: s.updated_at.utc.iso8601,
      title: s.title,
      matching_message: s.matching_message
    }
  end

  def format_timestamp(time)
    date = Rainbow(time.strftime("%Y-%m-%d")).green
    t = Rainbow("T").faint
    hms = Rainbow(time.strftime("%H:%M:%S")).green
    "#{date}#{t}#{hms}"
  end

  def format_message(text, pattern)
    text.lines.map { |l|
      styled = if pattern
                 l.rstrip.split(/(#{pattern.source})/i).map { |part|
                   pattern.match?(part) ? Rainbow(part).underline : Rainbow(part).faint
                 }.join
               else
                 Rainbow(l.rstrip).faint.to_s
               end
      "  #{Rainbow('|').faint} #{styled}"
    }.join("\n")
  end

  def format_session(s, pattern: nil)
    lines = []
    lines << "#{Rainbow(s.session_id).yellow} from #{format_timestamp(s.started_at)} to #{format_timestamp(s.updated_at)}"
    lines << "  #{Rainbow(s.title).bright.white}" if s.title
    lines << "  #{Rainbow(simplify_path(s.project_dir)).cyan}"
    lines << format_message(s.matching_message, pattern)
    lines.join("\n")
  end

  subcommand "list", "List recent sessions" do

    def execute
      if sessions.empty?
        warn "No sessions found"
        return
      end

      if json?
        puts JSON.pretty_generate(sessions.map { |s| session_to_hash(s) })
      else
        Rainbow.enabled = $stdout.tty?
        pattern = Regexp.new(Regexp.escape(matching), Regexp::IGNORECASE) if matching
        sessions.each { |s| puts format_session(s, pattern: pattern); puts }
      end
    end

  end

  subcommand "select", "Interactively select a session" do

    def execute
      if sessions.empty?
        warn "No sessions found"
        return
      end

      Rainbow.enabled = true
      pattern = Regexp.new(Regexp.escape(matching), Regexp::IGNORECASE) if matching
      items = sessions.reverse.map { |s| "#{format_session(s, pattern: pattern)}\n" }

      selected_text = fzf_select(items)
      return unless selected_text

      # Match by session ID (first thing on the first line)
      session_id = selected_text.lines.first&.split&.first
      selected = sessions.find { |s| s.session_id == session_id }
      return unless selected

      if json?
        puts JSON.pretty_generate(session_to_hash(selected))
      else
        puts "#{selected.session_id} in #{selected.project_dir}"
      end
    end

    private

    def fzf_select(items)
      IO.popen(["fzf", "--read0", "--print0", "--ansi", "--no-sort"], "r+") do |io|
        io.write(items.join("\0"))
        io.close_write
        result = io.read.chomp("\0")
        return nil if result.empty?

        result
      end
    rescue Errno::ENOENT
      warn "fzf is required for 'select'"
      nil
    end

  end

end
